# Copie este arquivo pra ../keystore/keystore.properties (fora do repositório)
# e preencha com os dados reais da sua chave de assinatura.
# NUNCA comite o arquivo keystore.properties real nem o .jks - eles são secretos.
storePassword=SUA_SENHA_AQUI
keyPassword=SUA_SENHA_AQUI
keyAlias=redebenedetti
storeFile=C:/Android/projects/keystore/rede-benedetti.jks
